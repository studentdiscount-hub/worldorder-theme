<section class="kg-pagefly-image-home-section kg-image-banner-2 section-{{ section.id }}">
  <div class="kg-inner-hero-content">
    <div class="page-width">
      {% if section.settings.desktop_image != blank or section.settings.mobile_image != blank %}
        <picture class="kg-hero-picture">
          {%- if section.settings.mobile_image != blank -%}
            <!-- Serve mobile-specific asset up to 749px -->
            <source
              media="(max-width: 749px)"
              srcset="
                {{ section.settings.mobile_image | image_url: width: 480 }} 480w,
                {{ section.settings.mobile_image | image_url: width: 720 }} 720w,
                {{ section.settings.mobile_image | image_url: width: 960 }} 960w,
                {{ section.settings.mobile_image | image_url: width: 1200 }} 1200w"
              sizes="100vw">
          {%- endif -%}

          {%- assign desktop_alt = section.settings.desktop_alt | default: shop.name -%}
          {%- assign desktop_classes = 'kg-hero-img' -%}
          {{ section.settings.desktop_image
            | default: section.settings.mobile_image
            | image_tag:
              widths: '800, 1200, 1600, 2000, 2400',
              sizes: '(max-width: 749px) 100vw, 100vw',
              alt: desktop_alt,
              class: desktop_classes,
              loading: 'lazy',
              decoding: 'async' }}
        </picture>
      {% endif %}
    </div>
  </div>
</section>

{%- style -%}
/* Scoped styles for this section only */
.section-{{ section.id }} .kg-hero-picture {
  display: block;
  width: 100%;
  max-width: 1600px;      /* feel free to adjust or remove for true full-bleed */
  margin-inline: auto;
  overflow: clip;
  border-radius: 16px;    /* modern soft corners */
}

.section-{{ section.id }} .kg-hero-img {
  display: block;
  inline-size: 100%;
  block-size: auto;
  aspect-ratio: var(--wo-hero-aspect, auto); /* if set via CSS var elsewhere */
  object-fit: cover;
  transform: translateZ(0); /* helps some mobile GPUs */
}

/* Optional: make it full-bleed when the page container is narrow */
@media (min-width: 990px) {
  .section-{{ section.id }} .kg-hero-picture {
    border-radius: 18px;
  }
}

/* Respect reduced motion */
@media (prefers-reduced-motion: no-preference) {
  .section-{{ section.id }} .kg-hero-img {
    transition: filter .25s ease;
  }
  .section-{{ section.id }} .kg-hero-img:hover {
    filter: brightness(0.98);
  }
}
{%- endstyle -%}

{% schema %}
{
  "name": "New Home Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "desktop_image",
      "label": "Desktop Image"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile Image (optional)"
    },
    {
      "type": "text",
      "id": "desktop_alt",
      "label": "Alt text (accessibility)",
      "default": "Hero banner"
    }
  ],
  "presets": [
    {
      "name": "New Home Banner"
    }
  ]
}
{% endschema %}