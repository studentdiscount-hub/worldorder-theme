<section class="kg-canvas-first-section-main">
  <div class="page-width">
    <div class="kg-canvas-flex-box">
      {% if section.settings.kg_url != blank %}
      <div class="kg-inner-iframes">
        <iframe 
          id="kg-dynamic-iframe"
          data-testid="embed-iframe"
          src="{{ section.settings.kg_url }}"
          width="100%"
          style="border-radius:12px; border:none; overflow:hidden; height:600px;"
          frameborder="0"
          allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
          loading="lazy">
        </iframe>
      </div>
      {% endif %}
    </div>
  </div>
</section>

<script>
  // --- Auto-resize iframe height based on content or viewport ---
  document.addEventListener("DOMContentLoaded", function() {
    const iframe = document.getElementById("kg-dynamic-iframe");

    // Use viewport height as fallback
    function setIframeHeight() {
      if (!iframe) return;
      // Default height if content cannot be measured (e.g., cross-domain)
      const defaultHeight = window.innerHeight * 0.8; // 80% of screen height
      iframe.style.height = defaultHeight + "px";
    }

    // Set height immediately and on window resize
    setIframeHeight();
    window.addEventListener("resize", setIframeHeight);
  });
</script>

{% schema %}
{
  "name": "Spotify",
  "settings": [
    {
      "type": "url",
      "id": "kg_url",
      "label": "Url"
    }
  ],
  "presets": [
    {
      "name": "Spotify"
    }
  ]
}
{% endschema %}