<div data-pf-editor-version="gen-2" class="sc-bkSTSn eCpwvD __pf __pf_HgLy2HJI" id="__pf"><div data-pf-type="Body" class="sc-lgjIEp kNIIwQ pf-9_"><div data-pf-type="Layout" class="sc-bHnkpz klJjOQ pf-10_"><section data-section-id="pf-94a1" data-pf-type="FlexSection" class="sc-hceuva jkduKR pf-11_ pf-container-1 pf-color-scheme-1 kg-pagefly-header pf-lg-hide"><div class="sc-jeyqhx gyoqcw pf-flex-section"><div data-pf-type="Custom.HTML" class="sc-fPrdjK iFszLQ pf-12_"><!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Responsive Header</title>
  <style>
    body {
      margin: 0;
      background-color: #241f21ff;
      font-family: sans-serif;
    }

    header {
      background-color: #241f21ff;
      padding: 15px 25px;
      color: white;
    }

    .desktop-header,
    .mobile-header {
      display: none;
    }

    /* DESKTOP STYLE */
    .desktop-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .nav-left,
    .nav-right {
      display: flex;
      gap: 12px;
      font-size: 14px;
    }

    .logo-center {
      position: absolute;
      left: 50%;
      transform: translateX(-50%);
    }

    .logo-center img {
      height: 40px;
    }

    .nav-left a,
    .nav-right a {
      color: white;
      text-decoration: none;
    }

    .nav-left a:hover,
    .nav-right a:hover {
      text-decoration: underline;
    }

    /* MOBILE STYLE */
    .mobile-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .mobile-logo img {
      height: 36px;
    }

    .hamburger {
      display: flex;
      flex-direction: column;
      cursor: pointer;
    }

    .hamburger span {
      height: 3px;
      width: 24px;
      background: white;
      margin: 4px 0;
    }

    .mobile-menu {
      display: none;
      flex-direction: column;
      padding: 10px 0;
    }

    .mobile-menu a {
      padding: 12px 20px;
      color: white;
      text-decoration: none;
      border-top: 1px solid #1c1c1c;
      background: #241f21ff;
    }

    .mobile-menu a:hover {
      background: #1c1c1c;
    }

    .mobile-menu.active {
      display: flex;
    }

    /* RESPONSIVE RULES */
    @media (max-width: 768px) {
      .desktop-header {
        display: none;
      }

      .mobile-header {
        display: flex;
      }
    }

    @media (min-width: 769px) {

      .mobile-header,
      .mobile-menu {
        display: none !important;
      }

      .desktop-header {
        display: flex;
      }
    }
  </style>
</head>

<body>

  <!-- DESKTOP HEADER -->
  <header class="desktop-header">
    <div class="nav-left">
      <a href="https://worldorderhq.com/">home</a> |
      <a href="https://worldorderhq.com/collections/all">catalog</a> |
      <a href="https://worldorderhq.com/pages/about">about</a>
    </div>
    <div class="logo-center">
      <img src="https://cdn.shopify.com/s/files/1/0689/3237/0623/files/logo.png?v=1752852002" alt="Logo">
    </div>
    <div class="nav-right">
      <a href="https://worldorderhq.com/pages/canvas">canvas</a> |
      <a href="https://worldorderhq.com/pages/contact">contact</a>
    </div>
  </header>

  <!-- MOBILE HEADER -->
  <header class="mobile-header">
    <div class="mobile-logo">
      <img src="https://cdn.shopify.com/s/files/1/0689/3237/0623/files/logo.png?v=1752852002" alt="Logo">
    </div>
    <div class="hamburger" onclick="toggleMenu()">
      <span></span>
      <span></span>
      <span></span>
    </div>
  </header>

  <!-- MOBILE MENU -->
  <div class="mobile-menu" id="mobileMenu">
    <a href="https://worldorderhq.com/">home</a>
    <a href="https://worldorderhq.com/collections/all">catalog</a>
    <a href="https://worldorderhq.com/pages/about">about</a>
    <a href="https://worldorderhq.com/pages/canvas">canvas</a>
    <a href="https://worldorderhq.com/pages/contact">contact</a>
  </div>

  <script>
    function toggleMenu() {
      document.getElementById("mobileMenu").classList.toggle("active");
    }
  </script>

</body>

