{{ 'wo-theme.css' | asset_url | stylesheet_tag }}
<style>
.wo-about-hero{background:#262626!important;padding:80px 48px 72px!important;overflow:hidden!important;position:relative!important;}
.wo-about-hero::before{display:none!important;}
.wo-about-hero__coords{font-family:'Space Mono',monospace!important;font-size:11px!important;letter-spacing:0.4em!important;color:rgba(242,243,238,0.6)!important;margin-bottom:40px!important;display:flex!important;flex-wrap:wrap!important;align-items:center!important;}
.wo-about-hero__coords span+span::before{content:'\00B7'!important;margin:0 10px!important;color:#5F1804!important;}
.wo-about-hero__headline{font-family:'Big Shoulders Display',sans-serif!important;font-weight:900!important;font-size:clamp(40px,7vw,72px)!important;line-height:0.92!important;text-transform:uppercase!important;color:#F2F3EE!important;margin-bottom:40px!important;}
.wo-about-hero__headline span{color:#5F1804!important;display:block!important;}
.wo-manifesto-lines{list-style:none!important;padding:0!important;margin:0!important;max-width:580px!important;border-top:1px solid rgba(242,243,238,0.08)!important;}
.wo-manifesto-lines li{list-style:none!important;}
.wo-manifesto-lines li::marker{content:none!important;}
.wo-manifesto-lines__item{padding:22px 0!important;border-bottom:1px solid rgba(242,243,238,0.07)!important;font-family:'Cormorant Garamond',serif!important;font-size:clamp(15px,1.8vw,20px)!important;line-height:1.5!important;color:rgba(242,243,238,0.6)!important;display:flex!important;gap:20px!important;align-items:flex-start!important;}
.wo-manifesto-lines__item em{font-style:normal!important;color:#F2F3EE!important;}
.wo-manifesto-lines__num{font-family:'Space Mono',monospace!important;font-size:8px!important;letter-spacing:0.2em!important;color:#5F1804!important;margin-top:5px!important;flex-shrink:0!important;width:24px!important;}
.wo-framework{display:grid!important;grid-template-columns:repeat(3,1fr)!important;background:#F2F3EE!important;border-top:1px solid rgba(38,38,38,0.1)!important;}
.wo-framework__cell{padding:44px 36px!important;border-right:1px solid rgba(38,38,38,0.1)!important;}
.wo-framework__cell:last-child{border-right:none!important;}
.wo-framework__num{font-family:'Cormorant Garamond',serif!important;font-size:72px!important;font-weight:300!important;line-height:1!important;color:rgba(38,38,38,0.08)!important;margin-bottom:16px!important;}
.wo-framework__word{font-family:'Big Shoulders Display',sans-serif!important;font-weight:900!important;font-size:28px!important;letter-spacing:0.06em!important;text-transform:uppercase!important;color:#262626!important;margin-bottom:12px!important;}
.wo-framework__word--void{color:#5F1804!important;}
.wo-framework__desc{font-family:'Cormorant Garamond',serif!important;font-style:italic!important;font-size:14px!important;line-height:1.7!important;color:#837C6C!important;}
.wo-about-close{background:#F2F3EE!important;padding:64px 48px!important;display:flex!important;justify-content:space-between!important;align-items:flex-end!important;border-top:1px solid rgba(38,38,38,0.08)!important;margin-bottom:0!important;}
.wo-about-close__line{font-family:'Cormorant Garamond',serif!important;font-size:clamp(17px,2.2vw,26px)!important;font-style:italic!important;max-width:500px!important;line-height:1.55!important;color:#262626!important;border:none!important;padding:0!important;margin:0!important;}
.wo-never-numb{font-family:'Space Mono',monospace!important;font-size:11px!important;letter-spacing:0.3em!important;color:#5F1804!important;text-align:right!important;line-height:2!important;}
@media(max-width:768px){
.wo-about-hero{padding:56px 24px 48px!important;}
.wo-about-hero__coords{font-size:10px!important;margin-bottom:28px!important;}
.wo-about-hero__headline{font-size:clamp(36px,12vw,56px)!important;margin-bottom:28px!important;}
.wo-manifesto-lines__item{font-size:clamp(14px,3.8vw,18px)!important;gap:14px!important;}
.wo-framework{grid-template-columns:1fr!important;}
.wo-framework__cell{padding:32px 24px!important;border-right:none!important;border-bottom:1px solid rgba(38,38,38,0.1)!important;}
.wo-framework__cell:last-child{border-bottom:none!important;}
.wo-about-close{flex-direction:column!important;gap:28px!important;align-items:flex-start!important;padding:44px 24px!important;}
.wo-never-numb{text-align:left!important;}
}
</style>
<div class="wo-about-hero">
<div class="wo-about-hero__coords"><span>38.9764 N</span><span>76.4896 W</span><span>Est. 2024</span></div>
<h1 class="wo-about-hero__headline">Pain.<br>Power.<br><span>Peace.</span></h1>
<ul class="wo-manifesto-lines">
<li class="wo-manifesto-lines__item"><span class="wo-manifesto-lines__num">I.</span><span>World Order began as a question no one else was asking. <em>What do you wear when the world stops making sense?</em></span></li>
<li class="wo-manifesto-lines__item"><span class="wo-manifesto-lines__num">II.</span><span>Not armor. Not costume. A uniform. Something you reach for when the noise gets loud and you still have to show up.</span></li>
<li class="wo-manifesto-lines__item"><span class="wo-manifesto-lines__num">III.</span><span>We come from Annapolis. 1649 on the bay, old money and new wounds. <em>Both things are true.</em></span></li>
<li class="wo-manifesto-lines__item"><span class="wo-manifesto-lines__num">IV.</span><span>Every piece sits between chaos and order. That gap is the VOID. That is where we work.</span></li>
<li class="wo-manifesto-lines__item"><span class="wo-manifesto-lines__num">V.</span><span>We are not trying to numb anything. The pain is the proof. <em>Only the numb mistake comfort for meaning.</em></span></li>
</ul>
</div>

<div class="wo-about-close">
<blockquote class="wo-about-close__line">Every face was part of a dream. So nothing here is accidental.</blockquote>
<div class="wo-never-numb">never.<br>numb.<br>again.</div>
</div>
