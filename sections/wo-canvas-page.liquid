{{ 'section-main-page.css' | asset_url | stylesheet_tag }}

{%- style -%}
  /* === CANVAS PAGE — WO Transmission Aesthetic === */
  /* Scoped to .wo-canvas (not :root) so these overrides don't bleed into
     the site header or any element outside the canvas section. */
  .wo-canvas {
    --wo-bg:     #1a1a18;
    --wo-cream:  #F5F4EF;
    --wo-red:    #5F1804;
    --wo-muted:  #837C6C;
    --wo-border: rgba(245,244,239,0.08);
  }

  .wo-canvas { background: var(--wo-bg); color: var(--wo-cream); position: relative; overflow: hidden; min-height: 100vh; }

  /* Grain overlay */
  .wo-canvas::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='1'/%3E%3C/svg%3E");
    opacity: 0.035;
    pointer-events: none;
    z-index: 0;
  }

  /* Horizontal scanline sweep */
  .wo-canvas__scan {
    position: fixed;
    left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent, rgba(95,24,4,0.4), transparent);
    animation: wo-scan 8s linear infinite;
    pointer-events: none;
    z-index: 1;
  }
  @keyframes wo-scan {
    0%   { top: -2px; opacity: 0; }
    5%   { opacity: 1; }
    95%  { opacity: 0.6; }
    100% { top: 100vh; opacity: 0; }
  }

  /* Header band */
  .wo-canvas__header {
    position: relative;
    z-index: 2;
    border-bottom: 1px solid var(--wo-border);
    padding: 48px 5rem 36px;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 24px;
  }

  .wo-canvas__coords {
    font-family: 'Space Mono', 'Courier New', monospace;
    font-size: 9px;
    letter-spacing: 0.45em;
    text-transform: uppercase;
    color: var(--wo-muted);
    line-height: 1.8;
  }
  .wo-canvas__coords span { display: block; }

  .wo-canvas__title-block { max-width: 640px; }

  .wo-canvas__label {
    font-family: 'Space Mono', 'Courier New', monospace;
    font-size: 9px;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: var(--wo-red);
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .wo-canvas__label::before {
    content: '';
    display: inline-block;
    width: 28px;
    height: 1px;
    background: var(--wo-red);
    flex-shrink: 0;
  }

  .wo-canvas__headline {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: clamp(36px, 5vw, 64px);
    font-weight: 300;
    font-style: italic;
    line-height: 1.1;
    color: var(--wo-cream);
    letter-spacing: 0.01em;
  }

  /* Ticker bar */
  .wo-canvas__ticker {
    position: relative;
    z-index: 2;
    border-bottom: 1px solid var(--wo-border);
    padding: 10px 0;
    overflow: hidden;
    background: rgba(95,24,4,0.06);
  }
  .wo-canvas__ticker-track {
    display: flex;
    gap: 0;
    animation: wo-ticker 40s linear infinite;
    width: max-content;
    white-space: nowrap;
  }
  .wo-canvas__ticker-track span {
    font-family: 'Space Mono', 'Courier New', monospace;
    font-size: 9px;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: var(--wo-muted);
    padding: 0 40px;
  }
  .wo-canvas__ticker-track span.wo-accent { color: var(--wo-red); }
  @keyframes wo-ticker {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  /* Main content area */
  .wo-canvas__body {
    position: relative;
    z-index: 2;
    max-width: 760px;
    margin: 0 auto;
    padding: 80px 5rem 120px;
  }

  .wo-canvas__body .wo-page-content {
    font-size: 15px;
    line-height: 1.9;
    color: rgba(245,244,239,0.78);
    font-family: 'Space Mono', 'Courier New', monospace;
  }
  .wo-canvas__body .wo-page-content p { margin-bottom: 1.6em; }
  .wo-canvas__body .wo-page-content a {
    color: var(--wo-cream);
    border-bottom: 1px solid var(--wo-red);
    text-decoration: none;
    transition: opacity 0.2s;
  }
  .wo-canvas__body .wo-page-content a:hover { opacity: 0.6; }
  .wo-canvas__body .wo-page-content h2,
  .wo-canvas__body .wo-page-content h3 {
    font-size: 10px;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--wo-red);
    margin: 56px 0 18px;
    font-weight: 500;
    font-family: 'Space Mono', 'Courier New', monospace;
  }
  .wo-canvas__body .wo-page-content h2::before,
  .wo-canvas__body .wo-page-content h3::before {
    content: '— ';
    color: var(--wo-muted);
  }

  /* Footer closing mark */
  .wo-canvas__close {
    position: relative;
    z-index: 2;
    border-top: 1px solid var(--wo-border);
    padding: 40px 5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 16px;
  }
  .wo-canvas__close-sig {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 13px;
    font-style: italic;
    color: var(--wo-muted);
    letter-spacing: 0.05em;
  }
  .wo-canvas__close-mark {
    font-family: 'Space Mono', 'Courier New', monospace;
    font-size: 9px;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: rgba(245,244,239,0.2);
  }

  /* Vertical rule accent */
  .wo-canvas__body::before {
    content: '';
    position: absolute;
    left: calc(5rem - 20px);
    top: 80px;
    bottom: 120px;
    width: 1px;
    background: linear-gradient(to bottom, var(--wo-red), transparent);
    opacity: 0.3;
  }

  /* Responsive */
  @media (max-width: 749px) {
    .wo-canvas__header { padding: 40px 1.5rem 28px; }
    .wo-canvas__body { padding: 60px 1.5rem 80px; }
    .wo-canvas__body::before { left: 0.75rem; }
    .wo-canvas__close { padding: 32px 1.5rem; }
    .wo-canvas__coords { display: none; }
  }

  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  /* Reduced motion — freeze canvas-specific animations */
  @media (prefers-reduced-motion: reduce) {
    .wo-canvas__scan {
      animation: none !important;
      display: none;
    }

    .wo-canvas__ticker-track {
      animation: none !important;
    }
  }
{%- endstyle -%}

<div class="wo-canvas section-{{ section.id }}-padding">

  <div class="wo-canvas__scan" aria-hidden="true"></div>

  <!-- Header -->
  <div class="wo-canvas__header">
    <div class="wo-canvas__title-block">
      <div class="wo-canvas__label">transmission</div>
      <h1 class="wo-canvas__headline">{{ page.title }}</h1>
    </div>
    <div class="wo-canvas__coords" aria-hidden="true">
      <span>38.9764&deg; N</span>
      <span>76.4896&deg; W</span>
      <span>Annapolis, MD</span>
    </div>
  </div>

  <!-- Ticker -->
  <div class="wo-canvas__ticker" aria-hidden="true">
    <div class="wo-canvas__ticker-track">
      <span>Friction over comfort</span>
      <span class="wo-accent">&bull;</span>
      <span>Signal over noise</span>
      <span class="wo-accent">&bull;</span>
      <span>The edge is clarity</span>
      <span class="wo-accent">&bull;</span>
      <span>Never numb again</span>
      <span class="wo-accent">&bull;</span>
      <span>Chaos &rarr; VOID &rarr; Order</span>
      <span class="wo-accent">&bull;</span>
      <span>World Order Est. 2024</span>
      <span class="wo-accent">&bull;</span>
      <!-- duplicate for seamless loop -->
      <span>Friction over comfort</span>
      <span class="wo-accent">&bull;</span>
      <span>Signal over noise</span>
      <span class="wo-accent">&bull;</span>
      <span>The edge is clarity</span>
      <span class="wo-accent">&bull;</span>
      <span>Never numb again</span>
      <span class="wo-accent">&bull;</span>
      <span>Chaos &rarr; VOID &rarr; Order</span>
      <span class="wo-accent">&bull;</span>
      <span>World Order Est. 2024</span>
      <span class="wo-accent">&bull;</span>
    </div>
  </div>

  <!-- Body content -->
  <div class="wo-canvas__body">
    <div class="wo-page-content rte{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
      <p style="font-size:9px;letter-spacing:0.3em;text-transform:uppercase;color:var(--wo-muted);margin-bottom:3em;">— This page updates with each drop. What you see is current.</p>
      {{ page.content }}
    </div>
  </div>

  <!-- Closing mark -->
  <div class="wo-canvas__close">
    <span class="wo-canvas__close-sig">the work continues.</span>
    <span class="wo-canvas__close-mark">WO &mdash; {{ 'now' | date: '%Y' }}</span>
  </div>

</div>

{% schema %}
{
  "name": "WO Canvas",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 0
    }
  ]
}
{% endschema %}
