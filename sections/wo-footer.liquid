<style>
  .wo-footer {
    background-color: #1A1A18;
    border-top: 1px solid rgba(242, 243, 238, 0.08);
    padding: 32px var(--wo-space-md) 24px;
    font-family: var(--wo-font-mono);
  }
  .wo-footer__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 16px;
    margin-bottom: 24px;
  }
  .wo-footer__copy {
    font-size: 11px;
    letter-spacing: 0.08em;
    color: rgba(242, 243, 238, 0.4);
    text-transform: lowercase;
  }
  .wo-footer__manifesto {
    font-size: 11px;
    letter-spacing: 0.2em;
    color: #5F1804;
    text-transform: lowercase;
  }
  .wo-footer__instagram {
    font-size: 11px;
    letter-spacing: 0.1em;
    color: rgba(242, 243, 238, 0.4);
    text-decoration: none;
    text-transform: lowercase;
    transition: color 0.2s;
  }
  .wo-footer__instagram:hover {
    color: #F2F3EE;
  }
  .wo-footer__policies {
    display: flex;
    flex-wrap: wrap;
    gap: 12px 24px;
    border-top: 1px solid rgba(242, 243, 238, 0.06);
    padding-top: 20px;
  }
  .wo-footer__policy-link {
    font-size: 10px;
    letter-spacing: 0.1em;
    color: rgba(242, 243, 238, 0.25);
    text-decoration: none;
    text-transform: lowercase;
    transition: color 0.2s;
  }
  .wo-footer__policy-link:hover {
    color: rgba(242, 243, 238, 0.6);
  }
</style>

<footer class="wo-footer">
  <div class="wo-footer__top">
    <span class="wo-footer__copy">&#xA9; {{ 'now' | date: '%Y' }} world order</span>
    <span class="wo-footer__manifesto">never. numb. again.</span>
    <a href="https://instagram.com/worldorderhq" class="wo-footer__instagram" target="_blank" rel="noopener">
      instagram &#x2192;
    </a>
  </div>
  <div class="wo-footer__policies">
    <a href="/policies/privacy-policy" class="wo-footer__policy-link">privacy</a>
    <a href="/policies/refund-policy" class="wo-footer__policy-link">refunds</a>
    <a href="/policies/terms-of-service" class="wo-footer__policy-link">terms</a>
    <a href="/policies/shipping-policy" class="wo-footer__policy-link">shipping</a>
    <a href="/policies/contact-information" class="wo-footer__policy-link">contact</a>
  </div>
</footer>

{% schema %}
{
  "name": "WO Footer",
  "settings": [],
  "presets": [{ "name": "WO Footer" }]
}
{% endschema %}
