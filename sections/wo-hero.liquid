{%- liquid
  assign hero_image  = section.settings.background_image
  assign drop_tag    = section.settings.drop_tag
  assign headline    = section.settings.headline | default: 'World Order'
  assign subline     = section.settings.subline
  assign cta_label   = section.settings.cta_label | default: 'Enter the catalog'
  assign cta_url     = section.settings.cta_url | default: '/collections/frontpage'
-%}

<section class="wo-hero" id="wo-hero">
  {%- if hero_image -%}
    <img
      class="wo-hero__bg"
      src="{{ hero_image | image_url: width: 2000 }}"
      alt="{{ hero_image.alt | escape }}"
      loading="eager"
      fetchpriority="high"
      width="{{ hero_image.width }}"
      height="{{ hero_image.height }}"
    >
  {%- endif -%}

  <div class="wo-hero__content">
    {%- if drop_tag != blank -%}
      <p class="wo-hero__sub">{{ drop_tag }}</p>
    {%- endif -%}

    <h1 class="wo-hero__headline wo-statement">{{ headline }}</h1>

    {%- if subline != blank -%}
      <p class="wo-hero__tagline wo-signal">{{ subline }}</p>
    {%- endif -%}

    {%- if cta_label != blank -%}
      <a class="wo-hero__cta" href="{{ cta_url }}">{{ cta_label }}</a>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "WO Hero",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "drop_tag",
      "label": "Drop tag / overline (Space Mono)"
    },
    {
      "type": "text",
      "id": "headline",
      "label": "Headline (Big Shoulders / statement voice)",
      "default": "World Order"
    },
    {
      "type": "textarea",
      "id": "subline",
      "label": "Subline (Caveat / signal voice)",
      "default": "uniforms for the individual,\nengineered with intention."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA label",
      "default": "Enter the catalog"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA URL"
    }
  ],
  "presets": [
    {
      "name": "WO Hero"
    }
  ]
}
{% endschema %}