{%- liquid
  assign hero_image = section.settings.hero_image
  assign headline   = section.settings.headline | default: 'World Order'
  assign tagline    = section.settings.tagline | default: 'there’s a shape forming in the dark'
  assign sub_text   = section.settings.sub_text
  assign cta_label  = section.settings.cta_label | default: 'enter'
  assign cta_url    = section.settings.cta_url | default: '/collections/frontpage'
-%}

<section class="wo-hero" id="wo-hero">
  {%- if hero_image -%}
    <img
      class="wo-hero__bg"
      src="{{ hero_image | image_url: width: 2000 }}"
      alt="{{ hero_image.alt | escape }}"
      loading="eager"
      fetchpriority="high"
      width="{{ hero_image.width }}"
      height="{{ hero_image.height }}"
    >
  {%- endif -%}

  <div class="wo-hero__content">
    {%- if sub_text != blank -%}
      <p class="wo-hero__sub">{{ sub_text }}</p>
    {%- endif -%}

    <h1 class="wo-hero__headline">{{ headline }}</h1>

    {%- if tagline != blank -%}
      <p class="wo-hero__tagline">{{ tagline }}</p>
    {%- endif -%}

    {%- if cta_label != blank -%}
      <a class="wo-hero__cta" href="{{ cta_url }}">{{ cta_label }}</a>
    {%- endif -%}
  </div>
</section>

<style>
  .wo-hero__cta {
    display: inline-block;
    font-family: 'Space Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--wo-cream, #F2F3EE);
    text-decoration: none;
    border-bottom: 1px solid rgba(242,243,238,0.35);
    padding-bottom: 3px;
    transition: color 0.2s, border-color 0.2s;
    margin-top: 8px;
  }
  .wo-hero__cta:hover {
    color: var(--wo-parchment, #E6D0AC);
    border-color: var(--wo-parchment, #E6D0AC);
  }
</style>

{% schema %}
{
  "name": "WO Hero",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "headline",
      "label": "Headline",
      "default": "World Order"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline (Caveat / signal voice)",
      "default": "there’s a shape forming in the dark"
    },
    {
      "type": "text",
      "id": "sub_text",
      "label": "Sub-label (Space Mono / overline)",
      "default": "Annapolis, MD — Est. MMXXIV"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA label",
      "default": "enter"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA URL"
    }
  ],
  "presets": [
    {
      "name": "WO Hero"
    }
  ]
}
{% endschema %}
