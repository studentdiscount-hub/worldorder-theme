{% comment %}
  WORLD ORDER — wo-manifesto-band.liquid
  Section: Manifesto band + Radio teaser (dark strip)
{% endcomment %}

{{ 'wo-theme.css' | asset_url | stylesheet_tag }}

<div class="wo-section wo-manifesto">
  <div class="wo-manifesto__text">
    {{ section.settings.manifesto_text | default: '<strong>Some nights I wear the silence like armor.</strong><br>Some mornings I wear noise like truth.<br><em style="color:rgba(242,243,238,0.35)">— never. numb. again.</em>' }}
  </div>
  <div class="wo-manifesto__brand">World Order</div>
</div>

{% if section.settings.show_radio_teaser %}
<div class="wo-section wo-radio-teaser">
  <div class="wo-radio-teaser__left">
    <div class="wo-disc"></div>
    <div>
      <div class="wo-radio-teaser__label">Now Listening</div>
      <div class="wo-radio-teaser__title">
        {{ section.settings.radio_title | default: 'World Order Radio — EP #001' }}
      </div>
    </div>
  </div>
  <div class="wo-radio-teaser__tracks">
    {{ section.settings.radio_tracks | newline_to_br }}
  </div>
  <a class="wo-radio-teaser__link" href="{{ section.settings.radio_url | default: '/pages/canvas' }}">
    Full tracklist →
  </a>
</div>
{% endif %}

{% schema %}
{
  "name": "WO — Manifesto Band",
  "tag": "div",
  "settings": [
    {
      "type": "html",
      "id": "manifesto_text",
      "label": "Manifesto text (HTML allowed)",
      "default": "<strong>Some nights I wear the silence like armor.</strong><br>Some mornings I wear noise like truth.<br><em style=\"color:rgba(242,243,238,0.35)\">— never. numb. again.</em>"
    },
    {
      "type": "checkbox",
      "id": "show_radio_teaser",
      "label": "Show Radio teaser strip",
      "default": true
    },
    {
      "type": "text",
      "id": "radio_title",
      "label": "Radio title",
      "default": "World Order Radio — EP #001"
    },
    {
      "type": "textarea",
      "id": "radio_tracks",
      "label": "Track listing (one per line)",
      "default": "DHL · Frank Ocean\nDiving board · redveil\nFruits of the Spirit · Jay Electronica"
    },
    {
      "type": "url",
      "id": "radio_url",
      "label": "Radio page URL"
    }
  ],
  "presets": [
    {
      "name": "WO — Manifesto Band"
    }
  ]
}
{% endschema %}
