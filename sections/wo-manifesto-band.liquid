{%- liquid
  assign headline     = section.settings.headline | default: 'Never. Numb. Again.'
  assign manifesto    = section.settings.manifesto_text
  assign brand_line   = section.settings.brand_line
-%}

<section class="wo-manifesto" id="wo-manifesto">
  {%- if headline != blank -%}
    <h2 class="wo-manifesto__headline wo-statement">{{ headline }}</h2>
  {%- endif -%}

  {%- if manifesto != blank -%}
    <p class="wo-manifesto__text">{{ manifesto }}</p>
  {%- endif -%}

  {%- if brand_line != blank -%}
    <span class="wo-manifesto__brand wo-signal">{{ brand_line }}</span>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "WO Manifesto Band",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "headline",
      "label": "Statement headline (Big Shoulders / all caps)",
      "default": "Never. Numb. Again."
    },
    {
      "type": "textarea",
      "id": "manifesto_text",
      "label": "Manifesto text (EB Garamond italic)",
      "default": "Committed to living with the friction of truth over the comfort of a lie."
    },
    {
      "type": "text",
      "id": "brand_line",
      "label": "Brand line (Caveat / signal voice)",
      "default": "— world order"
    }
  ],
  "presets": [
    {
      "name": "WO Manifesto Band"
    }
  ]
}
{% endschema %}
