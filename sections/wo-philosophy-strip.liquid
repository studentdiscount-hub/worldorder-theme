{% comment %}
  WORLD ORDER -- wo-philosophy-strip.liquid
  Pain Arrow Power Arrow Peace. Dark field. Narrow band.
  The brand's narrative arc made visual.
{% endcomment %}

<section class="wo-philosophy-strip">
  <div class="wo-philosophy-strip__inner">
    <div class="wo-philosophy-strip__step">
      <span class="wo-philosophy-strip__word">Pain</span>
      <span class="wo-philosophy-strip__desc">Resentment<br>as resistance</span>
    </div>
    <div class="wo-philosophy-strip__step">
      <span class="wo-philosophy-strip__word">Power</span>
      <span class="wo-philosophy-strip__desc">Earned<br>through the work</span>
    </div>
    <div class="wo-philosophy-strip__step">
      <span class="wo-philosophy-strip__word">Peace</span>
      <span class="wo-philosophy-strip__desc">The only kind<br>worth having</span>
    </div>
  </div>
</section>

