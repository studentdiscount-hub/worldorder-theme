<section class="wo-products-strip" style="padding: var(--wo-space-lg) var(--wo-space-md);">
  <div class="wo-products-strip__grid">
    {%- for product in collections[section.settings.collection].products limit: section.settings.product_limit -%}
      <a href="{{ product.url }}" class="wo-product-card">
        <div class="wo-product-card__image-wrap">
          {%- if product.featured_image -%}
            <img
              src="{{ product.featured_image | image_url: width: 800 }}"
              srcset="{{ product.featured_image | image_url: width: 400 }} 400w,
                      {{ product.featured_image | image_url: width: 800 }} 800w,
                      {{ product.featured_image | image_url: width: 1200 }} 1200w"
              sizes="(max-width: 768px) 100vw, (max-width: 990px) 50vw, 33vw"
              alt="{{ product.featured_image.alt | default: product.title }}"
              class="wo-product-card__img"
              loading="lazy"
              width="800"
              height="1067"
            >
          {%- else -%}
            <div class="wo-product-card__no-image"></div>
          {%- endif -%}
        </div>
        <div class="wo-product-card__info">
          <span class="wo-product-card__name">{{ product.title }}</span>
          <span class="wo-product-card__price">{{ product.price | money }}</span>
        </div>
      </a>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "WO Products Strip",
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "product_limit",
      "min": 2,
      "max": 6,
      "step": 1,
      "label": "Number of products",
      "default": 3
    }
  ],
  "presets": [{ "name": "WO Products Strip" }]
}
{% endschema %}
