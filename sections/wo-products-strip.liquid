{%- liquid
  if section.settings.collection != blank
    assign source_collection = collections[section.settings.collection]
  else
    assign source_collection = collections.all
  endif
-%}

<section class="wo-products-strip" style="padding: var(--wo-space-lg) var(--wo-space-md);">
  {%- if section.settings.heading != blank -%}
    <h2 class="wo-products-strip__heading">{{ section.settings.heading }}</h2>
  {%- endif -%}
  <div class="wo-products-strip__grid">
    {%- for product in source_collection.products limit: section.settings.product_limit -%}
      <a href="{{ product.url }}" class="wo-product-card">
        <div class="wo-product-card__image-wrap">
          {%- if product.featured_image -%}
            <img
              src="{{ product.featured_image | image_url: width: 800 }}"
              alt="{{ product.featured_image.alt | default: product.title }}"
              class="wo-product-card__img"
              loading="lazy"
            >
          {%- else -%}
            <div class="wo-product-card__no-image"></div>
          {%- endif -%}
        </div>
        <div class="wo-product-card__info">
          <span class="wo-product-card__name">{{ product.title }}</span>
          <span class="wo-product-card__price">{{ product.price | money }}</span>
        </div>
      </a>
    {%- endfor -%}
  </div>
  {%- if section.settings.show_view_all -%}
    <div class="wo-products-strip__footer">
      <a href="{{ source_collection.url }}" class="wo-products-strip__link">
        {{ section.settings.view_all_label | default: 'View all' }}
        <span aria-hidden="true"> →</span>
      </a>
    </div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "WO Products Strip",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Latest Pieces"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection (leave blank for all products)"
    },
    {
      "type": "range",
      "id": "product_limit",
      "min": 2,
      "max": 6,
      "step": 1,
      "label": "Number of products",
      "default": 3
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show 'View all' link",
      "default": true
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "View all label",
      "default": "Shop all"
    }
  ],
  "presets": [{ "name": "WO Products Strip" }]
}
{% endschema %}
