{%- assign spotify_url = section.settings.spotify_url | default: '#' -%}

<section class="wo-canvas" style="padding: var(--wo-space-xl) var(--wo-space-md); min-height: 60vh;">
  <div class="wo-canvas__inner" style="max-width: 680px; margin: 0 auto;">

    <div class="wo-canvas__header" style="margin-bottom: var(--wo-space-lg);">
      {%- if section.settings.ep_label != blank -%}
        <span class="wo-canvas__ep-label" style="font-family: var(--wo-font-mono); font-size: 10px; letter-spacing: 0.25em; text-transform: uppercase; color: var(--wo-burgundy); display: block; margin-bottom: 12px;">
          {{- section.settings.ep_label -}}
        </span>
      {%- endif -%}
      {%- if section.settings.ep_title != blank -%}
        <h1 class="wo-canvas__ep-title" style="font-family: var(--wo-font-mono); font-size: clamp(16px, 2vw, 20px); letter-spacing: 0.1em; text-transform: uppercase; font-weight: 700;">
          {{- section.settings.ep_title -}}
        </h1>
      {%- endif -%}
      {%- if section.settings.tagline != blank -%}
        <p class="wo-canvas__tagline" style="font-family: var(--wo-font-serif); font-style: italic; font-size: 15px; margin-top: 10px; opacity: 0.65;">
          {{- section.settings.tagline -}}
        </p>
      {%- endif -%}
    </div>

    {%- if section.blocks.size > 0 -%}
      <a href="{{ spotify_url }}" target="_blank" rel="noopener" class="wo-canvas__tracklist-link" style="display: block; text-decoration: none; color: inherit;">
        <ol class="wo-canvas__tracklist" style="list-style: none; padding: 0; margin: 0; border-top: 1px solid var(--wo-border);">
          {%- for block in section.blocks -%}
            {%- if block.type == 'track' -%}
              <li class="wo-canvas__track"
                  style="display: flex; align-items: baseline; justify-content: space-between; padding: 18px 0; border-bottom: 1px solid var(--wo-border); transition: opacity 0.2s;"
                  onmouseenter="this.style.opacity='0.6'" onmouseleave="this.style.opacity='1'">
                <span class="wo-canvas__track-left" style="display: flex; align-items: baseline; gap: 20px;">
                  <span style="font-family: var(--wo-font-mono); font-size: 10px; letter-spacing: 0.15em; color: var(--wo-burgundy); min-width: 24px;">
                    {{- block.settings.numeral -}}
                  </span>
                  <span style="font-family: var(--wo-font-mono); font-size: 12px; letter-spacing: 0.08em; text-transform: uppercase;">
                    {{- block.settings.song -}}
                  </span>
                </span>
                <span style="font-family: var(--wo-font-mono); font-size: 11px; opacity: 0.5; text-align: right;">
                  {{- block.settings.artist -}}
                </span>
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ol>
        {%- if spotify_url != '#' -%}
          <p style="font-family: var(--wo-font-mono); font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase; margin-top: 24px; opacity: 0.4;">
            Listen on Spotify →
          </p>
        {%- endif -%}
      </a>
    {%- endif -%}


    {%- if section.settings.show_email_capture -%}
      <div class="wo-canvas__email-capture" style="margin-top: var(--wo-space-xl); padding-top: var(--wo-space-lg); border-top: 1px solid var(--wo-border);">
        <span style="font-family: var(--wo-font-mono); font-size: 10px; letter-spacing: 0.25em; text-transform: uppercase; color: var(--wo-burgundy); display: block; margin-bottom: 12px;">
          {{ section.settings.email_eyebrow | default: 'The List' }}
        </span>
        <h2 style="font-family: var(--wo-font-serif); font-style: italic; font-weight: 300; font-size: clamp(20px, 2.5vw, 26px); color: inherit; line-height: 1.25; margin-bottom: 6px;">
          {{ section.settings.email_heading | default: 'Stay in the frequency.' }}
        </h2>
        <p style="font-family: var(--wo-font-mono); font-size: 12px; opacity: 0.45; margin-bottom: var(--wo-space-md);">
          {{ section.settings.email_subtext | default: 'New drops, editorial content, and transmissions from the studio.' }}
        </p>
        {%- form 'customer', id: 'CanvasEmailCapture' -%}
          <input type="hidden" name="contact[tags]" value="newsletter,canvas">
          {%- if form.posted_successfully? -%}
            <p style="font-family: var(--wo-font-mono); font-size: 12px; opacity: 0.65;">
              {{ section.settings.email_success | default: "You're in. We'll be in touch." }}
            </p>
          {%- else -%}
            <div style="display: flex; max-width: 440px; gap: 0;">
              <input
                type="email"
                name="contact[email]"
                style="flex:1; background: transparent; border: 1px solid rgba(26,26,24,0.25); border-right: none; font-family: var(--wo-font-mono); font-size: 12px; padding: 13px 16px; outline: none; color: inherit; border-radius: 0; -webkit-appearance: none;"
                placeholder="{{ section.settings.email_placeholder | default: 'your@email.com' }}"
                aria-label="Email address"
                autocomplete="email"
                required
                value="{{ form.email }}"
                {% if form.errors %}aria-invalid="true"{% endif %}
              >
              <button type="submit"
                style="background: var(--wo-burgundy, #5F1804); color: #F5F4EF; border: 1px solid var(--wo-burgundy, #5F1804); font-family: var(--wo-font-mono); font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase; padding: 13px 20px; cursor: pointer; border-radius: 0; white-space: nowrap;">
                {{ section.settings.email_cta | default: 'Subscribe' }}
              </button>
            </div>
            {%- if form.errors -%}
              <p style="font-family: var(--wo-font-mono); font-size: 11px; color: var(--wo-burgundy, #5F1804); margin-top: 8px;">{{ form.errors.translated_fields.email | capitalize }} {{ form.errors.messages.email }}</p>
            {%- endif -%}
          {%- endif -%}
        {%- endform -%}
      </div>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "WO Canvas",
  "settings": [
    { "type": "text",  "id": "ep_label",    "label": "Label",    "default": "World Order Radio" },
    { "type": "text",  "id": "ep_title",    "label": "Title",    "default": "There's a shape forming in the dark" },
    { "type": "text",  "id": "tagline",     "label": "Tagline"  },
    { "type": "url",   "id": "spotify_url", "label": "Spotify playlist URL" },
    { "type": "header", "content": "Email Capture" },
    { "type": "checkbox", "id": "show_email_capture", "label": "Show email capture", "default": true },
    { "type": "text", "id": "email_eyebrow",   "label": "Eyebrow", "default": "The List" },
    { "type": "text", "id": "email_heading",   "label": "Heading", "default": "Stay in the frequency." },
    { "type": "text", "id": "email_subtext",   "label": "Subtext", "default": "New drops, editorial content, and transmissions from the studio." },
    { "type": "text", "id": "email_placeholder", "label": "Placeholder", "default": "your@email.com" },
    { "type": "text", "id": "email_cta",      "label": "Button", "default": "Subscribe" },
    { "type": "text", "id": "email_success",  "label": "Success message", "default": "You're in. We'll be in touch." }
  ],
  "blocks": [
    {
      "type": "track",
      "name": "Track",
      "settings": [
        { "type": "text", "id": "numeral", "label": "Numeral (e.g. I, II, III)" },
        { "type": "text", "id": "song",    "label": "Song title" },
        { "type": "text", "id": "artist",  "label": "Artist" }
      ]
    }
  ],
  "max_blocks": 20,
  "presets": [{ "name": "WO Canvas" }]
}
{% endschema %}