{% comment %}
  WORLD ORDER — wo-radio-content.liquid
  Section: Canvas / Radio page — big disc hero, tracklist, context note, tie-back
{% endcomment %}

{% assign ep_label = section.settings.ep_label | default: 'EP #001' %}
{% assign ep_title = section.settings.ep_title | default: 'WORLD ORDER RADIO' %}
{% assign tagline  = section.settings.tagline  | default: 'The clothes arrived first. The music explains why.' %}

<div class="wo-radio-hero">
  <div class="wo-radio-hero__inner">
    <div class="wo-big-disc">
      <div class="wo-big-disc__title">{{ ep_title | split: ' ' | join: '<br>' }}</div>
      <div class="wo-big-disc__ep">{{ ep_label }}</div>
    </div>
    <div class="wo-radio-tagline">{{ tagline }}</div>
    <div class="wo-radio-powered">Powered by Student Discount</div>
  </div>
</div>

<div class="wo-spotify-section">
  <div class="wo-spotify-inner">
    <iframe
      src="https://open.spotify.com/embed/playlist/1XY3kVW7NmjD3DhlRABoeh?utm_source=generator&theme=0"
      width="100%"
      height="380"
      frameborder="0"
      allowfullscreen=""
      allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
      loading="lazy"
      style="border-radius:0; border:none;"
    ></iframe>
  </div>
</div>



{% schema %}
{
  "name": "WO — Radio Page",
  "tag": "div",
  "settings": [
    {
      "type": "url",
      "id": "spotify_url",
      "label": "Spotify Playlist URL",
      "info": "Paste the full Spotify playlist link here"
    },
    { "type": "text", "id": "ep_label", "label": "EP label", "default": "EP #001" },
    { "type": "text", "id": "ep_title", "label": "Big disc title", "default": "WORLD ORDER RADIO" },
    { "type": "text", "id": "tagline", "label": "Tagline" },
    { "type": "textarea", "id": "context_note", "label": "Context note copy" },
    { "type": "text", "id": "next_ep", "label": "Next EP note" },
    { "type": "text", "id": "tieback_label", "label": "Tie-back label", "default": "This EP Ships With" },
    { "type": "text", "id": "tieback_drop", "label": "Tie-back drop name", "default": "Standard Issue #001" },
    { "type": "url", "id": "tieback_url", "label": "Shop the drop URL" }
  ],
  "blocks": [{
    "type": "track",
    "name": "Track",
    "settings": [
      { "type": "text", "id": "numeral", "label": "Roman numeral", "default": "I" },
      { "type": "text", "id": "song", "label": "Song title" },
      { "type": "text", "id": "artist", "label": "Artist" }
    ]
  }],
  "presets": [{
    "name": "WO — Radio Page",
    "blocks": [
      { "type": "track", "settings": { "numeral": "I",   "song": "Call Me",             "artist": "Blood Orange, Park Hye Jin" } },
      { "type": "track", "settings": { "numeral": "II",  "song": "Diving Board",         "artist": "redveil" } },
      { "type": "track", "settings": { "numeral": "III", "song": "DHL",                  "artist": "Frank Ocean" } },
      { "type": "track", "settings": { "numeral": "IV",  "song": "Alesis",               "artist": "Mk.gee" } },
      { "type": "track", "settings": { "numeral": "V",   "song": "Fruits of the Spirit", "artist": "Jay Electronica" } }
    ]
  }]
}
{% endschema %}