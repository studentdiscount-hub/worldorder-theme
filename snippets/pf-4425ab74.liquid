<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Responsive Header</title>
  <style>
    body {
      margin: 0;
      background-color: #ffffff;
      font-family: sans-serif;
    }

    header {
      background-color: #ffffff;
      padding: 15px 25px;
      color: black;
    }

    .desktop-header,
    .mobile-header {
      display: none;
    }

    /* DESKTOP STYLE */
    .desktop-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      position: relative;
    }

    .nav-left,
    .nav-right {
      display: flex;
      gap: 12px;
      font-size: 14px;
    }

    .logo-center {
      position: absolute;
      left: 50%;
      transform: translateX(-50%);
    }

    .logo-center img {
      height: 40px;
    }

    .nav-left a,
    .nav-right a {
      color: black;
      text-decoration: none;
    }

    .nav-left a:hover,
    .nav-right a:hover {
      text-decoration: underline;
    }

    /* MOBILE STYLE */
    .mobile-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .mobile-logo img {
      height: 36px;
    }

    .hamburger {
      display: flex;
      flex-direction: column;
      cursor: pointer;
    }

    .hamburger span {
      height: 3px;
      width: 24px;
      background: black;
      margin: 4px 0;
    }

    .mobile-menu {
      display: none;
      flex-direction: column;
      padding: 10px 0;
    }

    .mobile-menu a {
      padding: 12px 20px;
      color: black;
      text-decoration: none;
      border-top: 1px solid #e0e0e0;
      background: #ffffff;
    }

    .mobile-menu a:hover {
      background: #f7f7f7;
    }

    .mobile-menu.active {
      display: flex;
    }

    /* RESPONSIVE RULES */
    @media (max-width: 768px) {
      .desktop-header {
        display: none;
      }

      .mobile-header {
        display: flex;
      }
    }

    @media (min-width: 769px) {

      .mobile-header,
      .mobile-menu {
        display: none !important;
      }

      .desktop-header {
        display: flex;
      }
    }
  </style>
</head>

<body>

  <!-- DESKTOP HEADER -->
  <header class="desktop-header">
    <div class="nav-left">
