{% comment %}
  WORLD ORDER — wo-figure.liquid
  Image primitive (Layer 2). Wraps every image on the site.
  Enforces the Obscured Identity rule (Bible Pillar 1) for portraits.

  RESTORED May 4, 2026: this snippet was inlined per commit 79f0f9a
  as a Shopify GitHub sync workaround. With Layer 2 primitives now
  shipping deliberately on Day 1, the snippet is safe to restore.

  USAGE:
    {% render 'wo-figure',
       image: section.settings.photo,
       subject: 'person',                   // 'person' | 'product' | 'archive'
       sizes: '100vw',
       widths: '800,1200,1600,2200',
       loading: 'eager',
       fetchpriority: 'high',
       alt: 'World Order archival portrait' %}

  PARAMS:
    image          — Shopify image object. Required.
    subject        — 'person' (Obscured Identity blur, NON-NEGOTIABLE),
                     'product' (flat-lay, no blur),
                     'archive' (grayscale + grain, no blur, for non-portrait
                     editorial photography).
                     Defaults to 'archive' if omitted.
    sizes          — sizes attribute. Defaults to '100vw'.
    widths         — Comma-separated width values for srcset.
                     Defaults to '800,1200,1600,2200'.
    loading        — 'eager' | 'lazy'. Defaults to 'lazy'.
    fetchpriority  — 'high' | 'auto'. Defaults to 'auto'.
    alt            — Alt text. Falls back to image.alt then a generic.

  CRITICAL: subject='person' applies the brand-non-negotiable
  Obscured Identity blur. This is enforced in CSS, not optional in
  markup. If a face needs to be visible, the photo does not belong
  on the site.
{% endcomment %}

{%- liquid
  assign fig_class = 'wo-figure'
  case subject
    when 'person'
      assign fig_class = 'wo-figure wo-figure--person'
      assign data_subject = 'person'
    when 'product'
      assign fig_class = 'wo-figure wo-figure--product'
      assign data_subject = 'product'
    else
      assign fig_class = 'wo-figure wo-figure--archive'
      assign data_subject = 'archive'
  endcase

  assign img_sizes = sizes | default: '100vw'
  assign img_widths = widths | default: '800,1200,1600,2200'
  assign img_loading = loading | default: 'lazy'
  assign img_fetchpriority = fetchpriority | default: 'auto'
  assign img_alt = alt | default: image.alt | default: 'World Order'
-%}

{%- if image != blank -%}
  <img
    class="{{ fig_class }}"
    data-wo-subject="{{ data_subject }}"
    src="{{ image | image_url: width: 1600 }}"
    srcset="
      {%- assign width_list = img_widths | split: ',' -%}
      {%- for w in width_list -%}
        {{ image | image_url: width: w | strip }} {{ w | strip }}w{%- unless forloop.last -%},{%- endunless -%}
      {%- endfor -%}"
    sizes="{{ img_sizes }}"
    width="{{ image.width }}"
    height="{{ image.height }}"
    alt="{{ img_alt | escape }}"
    loading="{{ img_loading }}"
    fetchpriority="{{ img_fetchpriority }}">
{%- endif -%}
