{%- comment -%}
  World Order — Fig. grammar snippet
  Renders a Fig. block per SoT Part III-C Primitive 2.

  Accepted params:
    number      (string)   — e.g. "03". Keep the leading zero. REQUIRED.
    word        (string)   — the reserved label word, e.g. "CYCLE". REQUIRED.
    caption     (string)   — italic caption beneath. Optional (2-8 words, lowercase, terminal period).
    rule        (boolean)  — render the hairline sage rule above the label. Default: true.
    variant     (string)   — "preorder" to apply .wo-fig__label--preorder modifier. Default: none.
    tag         (string)   — outer tag. Default: "div". Use "figcaption" when wrapping an image.

  Reserved number registry lives in Brand Bible Pillar 2 (Notion v4). Numbers are permanent;
  retiring a block retires the number — it is not reassigned.

  Usage:
    {% render 'wo-figure', number: '03', word: 'CYCLE',
       caption: 'chaos · repeats · returns · remains.' %}

    {% render 'wo-figure', number: '04', word: 'PRE-ORDER · SHIPS 14–21 DAYS',
       variant: 'preorder' %}
{%- endcomment -%}

{%- liquid
  assign fig_tag = tag | default: 'div'
  assign fig_rule = rule
  if fig_rule == nil
    assign fig_rule = true
  endif
  assign label_class = 'wo-fig__label'
  if variant == 'preorder'
    assign label_class = 'wo-fig__label wo-fig__label--preorder'
  endif
-%}

<{{ fig_tag }} class="wo-fig">
  {%- if fig_rule -%}<hr class="wo-fig__rule" />{%- endif -%}
  <span class="{{ label_class }}">FIG. {{ number }} &mdash; {{ word }}</span>
  {%- if caption != blank -%}
    <p class="wo-fig__caption">{{ caption }}</p>
  {%- endif -%}
</{{ fig_tag }}>
