{% comment %}
  WO Footer Symbol — Chess Knight SVG
  Drop this inside the footer section, after the copyright line.
  Usage: {% render 'wo-footer-symbol' %}
{% endcomment %}

<a href="/" class="wo-footer-symbol" aria-label="World Order">
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100" aria-hidden="true">
    {% comment %} Chess knight — geometric, minimal, brand-aligned {% endcomment %}
    <path d="M30 85 L30 75 L25 70 L25 60 L32 55 L28 45 L30 35
             C30 20 40 15 50 15
             C58 15 64 18 68 24
             L75 20 L72 30 L78 35
             L70 40 L72 50 L65 55
             L68 65 L62 68 L62 75 L62 85 Z
             M35 85 L60 85 M30 75 L62 75"
      stroke-linecap="round"
      stroke-linejoin="round"
      fill="none"
      stroke="currentColor"
      stroke-width="3.5"
    />
    {% comment %} Eye detail {% endcomment %}
    <circle cx="56" cy="27" r="3" fill="currentColor" />
    {% comment %} Axis cross — subtle brand mark at bottom {% endcomment %}
    <line x1="50" y1="88" x2="50" y2="96" stroke="currentColor" stroke-width="1.5" opacity="0.5"/>
    <line x1="46" y1="92" x2="54" y2="92" stroke="currentColor" stroke-width="1.5" opacity="0.5"/>
  </svg>
</a>
