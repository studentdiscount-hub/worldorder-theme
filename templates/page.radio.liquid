{% comment %}
  WORLD ORDER — page.radio.liquid
  Template: World Order Radio page
  Assign in Shopify: Pages > Radio / Canvas > Template > page.radio
{% endcomment %}

{{ 'wo-theme.css' | asset_url | stylesheet_tag }}

<div class="wo-section wo-radio-hero">
  <div class="wo-radio-hero__inner">

    <div class="wo-big-disc">
      <div class="wo-big-disc__title">WORLD<br>ORDER<br>RADIO</div>
      <div class="wo-big-disc__ep">EP #001</div>
    </div>

    <p class="wo-radio-hero__tagline">
      "The clothes arrived first.<br>The music explains why."
    </p>
    <p class="wo-radio-hero__powered">Powered by Student Discount</p>

  </div>
</div>

<div class="wo-section wo-tracklist">

  <div class="wo-track">
    <div class="wo-track__num">I</div>
    <div>
      <div class="wo-track__song">Call Me</div>
      <div class="wo-track__artist">Blood Orange, 박혜진 Park Hye Jin</div>
    </div>
    <span class="wo-track__badge">EP 001</span>
  </div>

  <div class="wo-track">
    <div class="wo-track__num">II</div>
    <div>
      <div class="wo-track__song">Diving Board</div>
      <div class="wo-track__artist">redveil</div>
    </div>
    <span class="wo-track__badge">EP 001</span>
  </div>

  <div class="wo-track">
    <div class="wo-track__num">III</div>
    <div>
      <div class="wo-track__song">DHL</div>
      <div class="wo-track__artist">Frank Ocean</div>
    </div>
    <span class="wo-track__badge">EP 001</span>
  </div>

  <div class="wo-track">
    <div class="wo-track__num">IV</div>
    <div>
      <div class="wo-track__song">Alesis</div>
      <div class="wo-track__artist">Mk.gee</div>
    </div>
    <span class="wo-track__badge">EP 001</span>
  </div>

  <div class="wo-track" style="grid-column: 1 / -1; max-width: 50%;">
    <div class="wo-track__num">V</div>
    <div>
      <div class="wo-track__song">Fruits of the Spirit</div>
      <div class="wo-track__artist">Jay Electronica</div>
    </div>
    <span class="wo-track__badge">EP 001</span>
  </div>

</div>

<div class="wo-section wo-radio-note">
  <p class="wo-radio-note__copy">
    Every World Order drop ships with a Radio EP.
    <em>The music is not a playlist — it's a context document.</em>
    Listen before you wear it. Or after. Either way, it changes what the clothes mean.
  </p>
  <div class="wo-radio-note__meta">
    EP #002<br>arriving with<br>Drop 002
  </div>
</div>

<div class="wo-section wo-radio-drop">
  <div>
    <div class="wo-radio-drop__label">This EP Ships With</div>
    <div class="wo-radio-drop__title">Standard Issue #001</div>
  </div>
  <a href="/collections/frontpage" class="wo-link">Shop the Drop →</a>
</div>
